# DocFlow AI — environment template
#
# The demo runs fully offline: every external dependency sits behind a typed
# interface with a Mock* implementation as the DEFAULT. Nothing below is
# required to run `npm run demo`, `npm test`, or the dashboard.
#
# Set MOCK_MODE=false AND provide the relevant keys to swap in real providers.

MOCK_MODE=true

# --- Server ---
PORT=4810

# --- LLM provider (classification / judge / repair stages) ---
# Real mode is powered by a frontier vision LLM via the chat-completions API.
# Set MOCK_MODE=false AND provide OPENAI_API_KEY to enable live extraction and
# the POST /api/documents/upload endpoint. Models are configurable:
OPENAI_API_KEY=
# Vision + repair model (vision-capable). Default: gpt-4o
OPENAI_MODEL=gpt-4o
# Cheaper model for classify/judge stages. Default: gpt-4o-mini
OPENAI_MODEL_CHEAP=gpt-4o-mini

# (Legacy seam — an alternate provider stub also exists but is not wired.)
ANTHROPIC_API_KEY=

# --- OCR engines (dual-engine merge) ---
# VisionEngine (semantic validation) reuses ANTHROPIC_API_KEY above.
# PaddleEngine (GPU layout analysis) needs a deployed PaddleOCR service:
PADDLE_OCR_URL=
# TextractEngine (compliance-grade tables) needs AWS credentials:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- Persistence ---
# Default store is in-memory. Point at MongoDB to persist pipeline runs:
MONGO_URL=

# --- Inbound channels (mocked connectors replay fixture traffic) ---
# Twilio (SMS/MMS ingestion) when MOCK_MODE=false:
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# IMAP inbox (email ingestion) when MOCK_MODE=false:
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=
